{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Frontend",
      "type": "shell",
      "command": "if (Test-Path package.json) { npm run build } else { Write-Host 'No frontend/package.json found. Skipping frontend build.' }",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    },
    {
      "label": "Copy Frontend to Backend",
      "type": "shell",
      "command": "if (Test-Path \"${workspaceFolder}/frontend/dist\") { Copy-Item \"${workspaceFolder}/frontend/dist/*\" \"${workspaceFolder}/Leavepal/src/main/resources/static/\" -Recurse -Force } else { Copy-Item \"${workspaceFolder}/frontend/*\" \"${workspaceFolder}/Leavepal/src/main/resources/static/\" -Recurse -Force }"
    },
    {
      "label": "Package Spring Boot JAR",
      "type": "shell",
      "command": "mvn clean package -DskipTests",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run Spring Boot JAR",
      "type": "shell",
      "command": "java -jar target/prj1-1.0-SNAPSHOT.jar",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
